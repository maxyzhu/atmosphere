# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
build/
dist/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Editor ---
.vscode/
.idea/
*.swp
.DS_Store

# --- Secrets (NEVER commit API tokens) ---
.env
.env.local
*.key

